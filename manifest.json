{
  "manifest_version": 3,
  "name": "Twitch Auto Claimer",
  "version": "1.0.0",
  "description": "Automatically claims Twitch channel points rewards when they appear",
  "permissions": ["activeTab"],
  "host_permissions": ["*://*.twitch.tv/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}